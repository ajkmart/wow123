# AJKMart  Project Configuration
modules = ["nodejs-20", "python-3.11"]

# Smart Launch: Workflow logic integrated into one run command
run = """
# 1. Clean old processes
echo "🧹 Cleaning environment..."
fuser -k 5000/tcp 23744/tcp 3002/tcp 3003/tcp 4200/tcp || true

# 2. Performance & Path Setup
export NODE_OPTIONS="--max-old-space-size=4096"
export PNPM_HOME="/home/runner/.local/share/pnpm"
export PATH="$PNPM_HOME:$PATH"

# 3. Environment Variable Injection (From your Userenv)
export NODE_ENV="development"
export JWT_SECRET="7f3ec5deb5570aed1fe360dc1fa0c3ebb088ea2b62ffd9004f72a6dd5ebcdc3fc91f13f4e61ff5122b7b5f5f5299093f"
export ENCRYPTION_MASTER_KEY="81eece1b2f16cf732a2af17068a9052dfaf363102b41903779f2a82ef658f049"
export ADMIN_SECRET="iyH2XN2ni8PoonWRusJqM7uJ2pEocXDN"
export VITE_API_PROXY_TARGET="http://127.0.0.1:5000"

# 4. Dependency Check
STAMP="node_modules/.nix-install-stamp"
if [ ! -d "node_modules" ] || [ "pnpm-lock.yaml" -nt "$STAMP" ]; then
  echo "📦 Installing workspace dependencies..."
  pnpm install --no-frozen-lockfile && touch "$STAMP"
fi

echo "🚀 Starting Project Workflows..."

# 5. Parallel Microservices Launch (As per your workflow tasks)
(
  # API Server (Using your secure-start script)
  PORT=5000 node scripts/secure-start.mjs & \
  
  # Admin Panel (Using your specific port 23744)
  ADMIN_PORT_OVERRIDE=23744 ADMIN_DEV_PORT=23744 BASE_PATH=/admin/ pnpm --filter @workspace/admin dev & \
  
  # Vendor App
  VENDOR_DEV_PORT=3002 BASE_PATH=/vendor/ pnpm --filter @workspace/vendor-app dev & \
  
  # Rider App
  RIDER_DEV_PORT=3003 BASE_PATH=/rider/ pnpm --filter @workspace/rider-app dev & \
  
  # Customer App
  PORT=4200 BASE_PATH=/ EXPO_PUBLIC_DOMAIN=$REPLIT_EXPO_DEV_DOMAIN pnpm --filter @workspace/ajkmart dev:web
)
"""

# Deployment and Artifacts settings
[deployment]
run = ["pnpm", "start"]
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/secure-start.mjs"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 3003
externalPort = 80

[[ports]]
localPort = 3004
externalPort = 3003

[[ports]]
localPort = 3005
externalPort = 4200

[[ports]]
localPort = 4200
externalPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 19006
externalPort = 5173

[[ports]]
localPort = 23744
externalPort = 3000

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[userenv]

[userenv.shared]
VITE_API_PROXY_TARGET = "http://127.0.0.1:5000"
NODE_ENV = "development"
PORT = "5000"
ADMIN_DEV_PORT = "23744"
ADMIN_PORT_OVERRIDE = "23744"
VENDOR_DEV_PORT = "3002"
RIDER_DEV_PORT = "3003"
JWT_ISSUER = "ajkmart-dev"
ADMIN_SEED_USERNAME = "superadmin"
ADMIN_SEED_PASSWORD = "Admin@123"
ADMIN_SEED_EMAIL = "admin@ajkmart.com"
ADMIN_SEED_NAME = "Super Admin"
LOG_LEVEL = "debug"
PORT_FALLBACK_ENABLE = "true"
PORT_MAX_RETRIES = "10"
ALLOW_DEV_SEED = "true"
ADMIN_SEED_KEY = "local-dev-seed-ajkmart"
