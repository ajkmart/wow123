# ─────────────────────────────────────────────────────────────────────────────
# AJKMart Production Environment Template
#
# Copy this file to .env and fill in real values before running:
#   cp deploy/env.example .env
#   docker-compose up -d
#
# All secrets must be strong, unique random strings in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ── Caddy / Routing ───────────────────────────────────────────────────────────
# Public hostname Caddy listens on. Use your real domain for automatic TLS.
AJKMART_DOMAIN=localhost
# Filesystem root inside the container (do not change for Docker deployments).
APP_ROOT=/app
# Internal port for the API server (must match ecosystem.config.cjs API_PORT).
API_PORT=8080
# Internal port for the Expo mobile-web server (if used).
MOBILE_WEB_PORT=19006

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── JWT / Auth secrets ────────────────────────────────────────────────────────
JWT_SECRET=change-this-secret
ADMIN_JWT_SECRET=change-this-secret
ADMIN_REFRESH_SECRET=change-this-secret
ADMIN_SECRET=change-this-secret
ADMIN_ACCESS_TOKEN_SECRET=change-this-secret
ADMIN_REFRESH_TOKEN_SECRET=change-this-secret
ADMIN_CSRF_SECRET=change-this-secret
VENDOR_JWT_SECRET=change-this-secret
RIDER_JWT_SECRET=change-this-secret
JWT_ISSUER=ajkmart

# ── Admin seed (first-run admin account) ─────────────────────────────────────
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=change-this-password
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_NAME=Admin

# ── Security ──────────────────────────────────────────────────────────────────
ERROR_REPORT_HMAC_SECRET=change-this-secret
ENCRYPTION_MASTER_KEY=change-this-key-min-16-chars
ALLOWED_ORIGINS=https://yourdomain.com
ALLOWED_DOMAINS=yourdomain.com

# ── URLs ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://yourdomain.com
ADMIN_BASE_URL=https://yourdomain.com/admin
FRONTEND_URL=https://yourdomain.com
CLIENT_URL=https://yourdomain.com
EXPO_PUBLIC_DOMAIN=yourdomain.com

# ── Firebase (push notifications) ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Twilio (SMS OTP) ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Email ─────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SMTP_HOST=

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Maps ──────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
OSRM_API_URL=

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@example.com

# ── Object Storage (S3-compatible) ────────────────────────────────────────────
STORAGE_BUCKET_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET_NAME=
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=
SENTRY_DSN=
SENTRY_WEBHOOK_SECRET=
DB_POOL_MAX=10
